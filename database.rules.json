{
  "rules": {
    "sessions": {
      ".read": false,
      ".write": false,

      "$code": {
        ".read": true,
        ".write": "!data.exists()",
        ".validate": "newData.hasChildren(['topic', 'status', 'createdBy', 'createdAt', 'cards', 'participants']) && $code.matches(/^[A-Z]{4}$/)",

        "topic": {
          ".validate": "newData.isString() && newData.val().length <= 10 && (newData.val() === 'food' || newData.val() === 'movie' || newData.val() === 'show')"
        },

        "status": {
          ".write": true,
          ".validate": "newData.isString() && (newData.val() === 'waiting' || newData.val() === 'active' || newData.val() === 'complete')"
        },

        "createdBy": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 64"
        },

        "createdAt": {
          ".validate": "newData.isNumber() && newData.val() <= now"
        },

        "round": {
          ".write": true,
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 20"
        },

        "location": {
          ".validate": "newData.hasChildren(['latitude', 'longitude', 'radiusMiles'])",
          "latitude": {
            ".validate": "newData.isNumber() && newData.val() >= -90 && newData.val() <= 90"
          },
          "longitude": {
            ".validate": "newData.isNumber() && newData.val() >= -180 && newData.val() <= 180"
          },
          "radiusMiles": {
            ".validate": "newData.isNumber() && newData.val() > 0 && newData.val() <= 100"
          },
          "$other": { ".validate": false }
        },

        "cards": {
          ".write": true,
          ".validate": "newData.hasChildren()",
          "$index": {
            ".validate": "newData.hasChild('id') && newData.hasChild('title')",
            "id": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 128" },
            "title": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 256" },
            "subtitle": { ".validate": "newData.isString() && newData.val().length <= 256" },
            "imageUrl": { ".validate": "newData.isString() && newData.val().length <= 1024" },
            "rating": { ".validate": "newData.isNumber()" },
            "details": {
              "$i": { ".validate": "newData.isString() && newData.val().length <= 512" }
            },
            "sourceUrl": { ".validate": "newData.isString() && newData.val().length <= 1024" },
            "meta": { ".validate": true }
          }
        },

        "participants": {
          ".write": true,
          ".validate": "newData.hasChildren()",

          "$deviceId": {
            ".validate": "newData.hasChild('name') && newData.hasChild('joinedAt') && $deviceId.length > 0 && $deviceId.length <= 64",

            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 30"
            },
            "joinedAt": {
              ".validate": "newData.isNumber()"
            },
            "completed": {
              ".write": true,
              ".validate": "newData.isBoolean()"
            },
            "connected": {
              ".write": true,
              ".validate": "newData.isBoolean()"
            },
            "lastConnected": {
              ".write": true,
              ".validate": "newData.isNumber()"
            },
            "swipes": {
              ".write": true,
              "$cardId": {
                ".validate": "newData.isBoolean()"
              }
            },
            "$other": { ".validate": false }
          }
        },

        "$other": { ".validate": false }
      }
    },

    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
